# Server
PORT=8080

# SQL Server (use double backslash for NTLM: DOMAIN\\username)
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=your_password
SQLSERVER_DATABASE=Staging
SQLSERVER_ENCRYPT=false
SQLSERVER_TRUST_CERT=true

# Redshift (optional)
REDSHIFT_DATABASE=glue_spectrum
REDSHIFT_WORKGROUP_NAME=serverless-workgroup

# AWS SSO Profile (must match a profile in ~/.aws/config)
AWS_PROFILE=data-prod
AWS_REGION=ap-southeast-1

# AWS S3
S3_BUCKET=prod-545009847083-analytics-reporting
S3_PREFIX=amylia/

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3

# ChromaDB (for RAG)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# RAG Data Directory
RAG_DATA_DIR=./data
